APP_PORT=9117
HEALTHCHECK_PORT=9117
TZ=UTC
UMASK=0027

# Путь к вашему config.yml (относительно расположения docker-compose.yml)
CONFIG_PATH=./config.yml

# Настройки базы данных
DB_NAME=jacred
DB_USER=jacred
DB_PASSWORD=jacred
# Полная строка подключения для приложения (по умолчанию использует переменные выше)
DB_CONNECTION=Host=db;Port=5432;Database=jacred;Username=jacred;Password=jacred;Timeout=30;CommandTimeout=60;

# Тег/имя образа при локальной сборке
IMAGE_NAME=jacred:local
